{
  "name": "terminal-quest",
  "version": "1.0.0",
  "description": "A terminal-based RPG adventure game built with Node.js and TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "test": "jest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "rpg",
    "terminal",
    "game",
    "cli",
    "adventure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "inquirer": "^9.2.12",
    "chalk": "^5.3.0",
    "figlet": "^1.7.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/inquirer": "^9.0.7",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
