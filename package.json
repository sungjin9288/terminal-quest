{
  "name": "terminal-quest",
  "version": "1.0.0",
  "description": "A terminal-based RPG adventure game built with Node.js and TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "play": "node scripts/start-game.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "test": "jest",
    "clean": "rimraf dist",
    "validate:quests": "npm run build && node scripts/validate-quest-balance.js",
    "validate:economy": "npm run build && node scripts/validate-economy-balance.js",
    "validate:playtime": "npm run build && node scripts/validate-playtime-balance.js",
    "validate:prompt-priority": "node scripts/validate-prompt-priority.js",
    "validate:data": "npm run build && node scripts/validate-data-integrity.js && node scripts/validate-quest-balance.js && node scripts/validate-economy-balance.js && node scripts/validate-playtime-balance.js",
    "balance:notes": "npm run build && node scripts/generate-balance-patch-notes.js",
    "balance:notes:dry": "npm run build && node scripts/generate-balance-patch-notes.js --dry-run",
    "verify:save-migration": "node scripts/verify-save-migration.js",
    "verify:package-launch": "node scripts/verify-package-launch.js",
    "verify:runtime-smoke": "node scripts/verify-runtime-smoke.js",
    "verify:release-artifacts": "node scripts/verify-release-artifacts.js",
    "release:signoff": "node scripts/release-signoff.js",
    "release:signoff:all": "node scripts/release-signoff-all.js",
    "release:check": "node scripts/release-readiness-check.js",
    "release:smoke": "node scripts/release-smoke-report.js",
    "release:candidate": "node scripts/release-candidate-gate.js",
    "release:package": "npm run build && node scripts/release-package.js",
    "release:package:dry": "npm run build && node scripts/release-package.js --dry-run"
  },
  "keywords": [
    "rpg",
    "terminal",
    "game",
    "cli",
    "adventure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "inquirer": "^9.2.12",
    "chalk": "^5.3.0",
    "figlet": "^1.7.0",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/inquirer": "^9.0.7",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
